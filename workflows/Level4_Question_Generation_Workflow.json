    {
      "parameters": {
        "jsCode": "// const items = $input.all();\n\n// const lessons = {};\n\n// for (const item of items) {\n//   const j = item.json;\n\n//   const lessonId = Number(j.lesson_id);\n//   if (!lessonId) continue;\n\n//   // Initialize lesson if not seen\n//   if (!lessons[lessonId]) {\n//     lessons[lessonId] = {\n//       id: lessonId,\n//       slug: j.lesson_slug,\n//       title: j.lesson_title,\n//       content_md: j.lesson_text || \"\",\n//       topic: j.topic,\n//       level: j.level,\n//       metadata: j.metadata || {},\n//       questions: []\n//     };\n//   }\n\n//   // Add questions\n//   const qaPairs = j.parsedQuestions?.qa_pairs || [];\n//   for (const qa of qaPairs) {\n//     lessons[lessonId].questions.push({\n//       id: lessons[lessonId].questions.length + 1,\n//       question: qa.question,\n//       answer: qa.answer,\n//       difficulty: qa.difficulty,\n//       category: qa.category\n//     });\n//   }\n// }\n\n// // Return one item per lesson\n// return Object.values(lessons).map(lesson => ({\n//   json: lesson\n// }));\n\nconst items = $input.all();\nconst lessons = {};\n\nfor (const item of items) {\n  const j = item.json;\n  const lessonId = Number(j.lesson_id);\n  if (!lessonId) continue;\n\n  // Initialize lesson\n  if (!lessons[lessonId]) {\n    lessons[lessonId] = {\n      id: lessonId,\n      slug: j.lesson_slug,\n      title: j.lesson_title,\n      topic: j.topic,\n      level: j.level,\n      metadata: j.metadata || {},\n      _chunks: [],          // temporary\n      questions: []\n    };\n  }\n\n  // Collect lesson text chunks\n  if (j.lesson_text) {\n    lessons[lessonId]._chunks.push({\n      index: j.chunk_index ?? 0,\n      text: j.lesson_text\n    });\n  }\n\n  // Collect questions\n  const qaPairs = j.parsedQuestions?.qa_pairs || [];\n  for (const qa of qaPairs) {\n    lessons[lessonId].questions.push({\n      id: lessons[lessonId].questions.length + 1,\n      question: qa.question,\n      answer: qa.answer,\n      difficulty: qa.difficulty,\n      category: qa.category\n    });\n  }\n}\n\n// Finalize lessons\nreturn Object.values(lessons).map(lesson => {\n  const content_md = lesson._chunks\n    .sort((a, b) => a.index - b.index)\n    .map(c => c.text)\n    .join(\"\\n\\n\");\n\n  delete lesson._chunks;\n\n  return {\n    json: {\n      ...lesson,\n      content_md\n    }\n  };\n});\n"
      },
