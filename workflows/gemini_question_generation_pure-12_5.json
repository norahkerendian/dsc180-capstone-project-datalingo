    {
      "parameters": {
        "jsCode": "// Your input item looks like:\n// {\n//   parsedQuestions: {\n//       lesson_text: \"...\",\n//       qa_pairs: [ ... ]\n//   }\n// }\n\n// 1) Read parsedQuestions safely\nconst pq = $json.parsedQuestions;\n\nif (!pq) {\n  throw new Error('Missing parsedQuestions in input');\n}\n\nconst qaPairs = Array.isArray(pq.qa_pairs) ? pq.qa_pairs : [];\n\nif (!qaPairs.length) {\n  return []; // nothing to output\n}\n\n// 2) Read lesson metadata from earlier Set node\nconst metaNode = $node['Set – Lesson Metadata1'].json || {};\n\nconst lesson_slug  = metaNode.lesson_slug  ?? null;\nconst lesson_title = metaNode.lesson_title ?? null;\nconst topic        = metaNode.topic        ?? null;\nconst level        = metaNode.level        ?? null;\n\n// 3) Flatten into one output item per QA pair\nreturn qaPairs.map((q, index) => ({\n  json: {\n    lesson_slug,\n    lesson_title,\n    topic,\n    level,\n    question: q.question,\n    answer: q.answer,\n    difficulty: typeof q.difficulty === 'number' ? q.difficulty : 1,\n    category: q.category || 'concept_check',\n    question_type: q.question_type || 'short_answer',\n    source: 'baseline',\n    index,\n  },\n}));\n"
      },
